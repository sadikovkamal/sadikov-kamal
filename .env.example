# Copy this file to .env.local and fill in values. Never commit .env.local.
#
# For Vercel deployment: set the same variables under
# Vercel → Project → Settings → Environment Variables.

# --- Database (required) ----------------------------------------------------
# Local Docker Postgres listens on host port 5434.
# Production: Neon connection string from https://neon.tech/console
DATABASE_URL=postgresql://sadikov_kamal_admin:dev_password_change_me@localhost:5434/sadikov_kamal

# --- Seed defaults (dev-only) -----------------------------------------------
# Used by `npm run db:seed`. The dev seed inserts when the email is new
# (`onConflictDoNothing`); changing these won't update an existing admin.
# In production, set these env vars when running `npm run db:seed:prod`
# (separately each time) — the prod seed refuses weak defaults.
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_ADMIN_NAME=Admin

# --- Auth -------------------------------------------------------------------
# Reserved for a future CSRF-signing key. Generate with:
#   openssl rand -hex 32
SESSION_SECRET=

# --- Cloudflare R2 (required in prod) ---------------------------------------
# 1) Create a bucket in the Cloudflare R2 dashboard (e.g. `sadikov-kamal-uploads`).
# 2) Enable the R2.dev public subdomain on that bucket → R2_PUBLIC_URL.
# 3) Create an API token with Object Read & Write scoped to that bucket only.
# 4) Account ID is shown at the top of the R2 page in the Cloudflare dashboard.
# Mirror these into Vercel project settings as well, otherwise the deployed
# app cannot upload.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=sadikov-kamal-uploads
R2_PUBLIC_URL=

# --- Cron auth (required in prod when Vercel Cron is active) ----------------
# Vercel Cron sends `Authorization: Bearer ${CRON_SECRET}` automatically when
# this env var is set on the project. The same value protects the manual
# backup endpoint from public access. Generate with:
#   openssl rand -hex 32
CRON_SECRET=
