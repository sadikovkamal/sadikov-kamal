# Copy this file to .env.local and fill in values. Never commit .env.local.

# --- Database (Phase 0/1) -----------------------------------------------------
# Local Docker Postgres listens on host port 5434 (5433 is used by another
# project on this machine). See docker-compose.yml.
DATABASE_URL=postgresql://provia_admin:dev_password_change_me@localhost:5434/provia

# --- Seed defaults (Phase 1) --------------------------------------------------
# Used by `npm run db:seed`. The seed only inserts when the email is new
# (`onConflictDoNothing`), so changing these won't update an existing admin.
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_ADMIN_NAME=Admin

# --- Auth (Phase 2) -----------------------------------------------------------
# Reserved for a future CSRF-signing key. The current session-token flow
# does not use it (tokens are random + DB-validated), but Phase 10 may.
SESSION_SECRET=

# --- Cloudflare R2 (Phase 4) --------------------------------------------------
# 1) Create a bucket in the Cloudflare R2 dashboard (e.g. `provia-uploads`).
# 2) Enable the R2.dev public subdomain on that bucket → R2_PUBLIC_URL.
# 3) Create an API token with Object Read & Write scoped to that bucket only.
# 4) Account ID is shown at the top of the R2 page in the Cloudflare dashboard.
# Mirror these into Vercel project settings as well, otherwise the deployed
# app cannot upload.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=provia-uploads
R2_PUBLIC_URL=
